#!/bin/sh /etc/rc.common
USE_PROCD=1
START=95
STOP=10

start_service() {
	procd_open_instance
	procd_set_param command /usr/sbin/tschedd /etc/tsched/tsched.conf /etc/tsched/tasks.conf
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param limits nofile="1024 1024"
	procd_close_instance
}

reload_service() {
	stop
	start
}
